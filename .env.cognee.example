# Cognee container env — copy to ".env.cognee". Passed to the Cognee MCP container
# via --env-file. PROVEN config (2026-06-26): cognify completes in ~28s.
#
# RECOMMENDED = HYBRID: Groq for extraction (fast + reliable structured output) +
# local Ollama embeddings (free). The local-only LLM alternative is at the bottom.
#
# Two URL gotchas that cost us hours (don't change them):
#   * LLM_ENDPOINT must end in /v1     (cognee POSTs {endpoint}/chat/completions)
#   * EMBEDDING_ENDPOINT must be the full /api/embed URL (cognee POSTs to it directly)

TRANSPORT_MODE=stdio

# ---- LLM (extraction) = Groq ----  (get a free key at https://console.groq.com)
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_ENDPOINT=https://api.groq.com/openai/v1
LLM_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY

# ---- Embeddings = local Ollama (free) ----
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://namma-cognee-ollama:11434/api/embed
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5

# ---- Storage: embedded files (local) ----
DB_PROVIDER=sqlite
VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=kuzu

# ---- PERSISTENCE (so memory survives restarts) ----
# Write the graph/vector/sqlite DBs to the mounted volume (-v cognee-data:/cognee-data).
# These are the real cognee env names (BaseConfig data_root/system_root/cache_root).
# The setup script pre-creates these dirs with write perms (the volume is root-owned,
# Cognee runs non-root). Without this, Cognee writes inside the container → resets on restart.
DATA_ROOT_DIRECTORY=/cognee-data/data
SYSTEM_ROOT_DIRECTORY=/cognee-data/system
CACHE_ROOT_DIRECTORY=/cognee-data/cache

COGNEE_SKIP_CONNECTION_TEST=true
ENABLE_BACKEND_ACCESS_CONTROL=false

# ===========================================================================
# FULLY-LOCAL ALTERNATIVE (no cloud, no key) — replace the LLM block above with:
#   LLM_PROVIDER=ollama
#   LLM_MODEL=qwen2.5:7b          # 3B models are too weak for cognee's structured
#   LLM_ENDPOINT=http://namma-cognee-ollama:11434/v1   # extraction; use 7B+.
#   LLM_API_KEY=ollama
# Reliable but slow on CPU — pre-build memory offline if you go this route.
#
# CLOUD TRACK: point at Cognee Cloud instead (dev plan code COGNEE-35).
