# Namma Agent (cloud-only) — environment template.
#
#   cp namma_agent/.env.example .env       # the repo loads ".env" from the project root
#
# Only the API key for the provider you use is required. Everything else is
# optional and the matching feature simply stays off if unset.
# Shell environment variables take precedence over .env at runtime.

# ── Provider API keys (set the one matching config.yaml provider.type) ──
# Anthropic (default). Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (or any OpenAI-compatible endpoint). https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini. https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Generic key name for a custom openai_compat endpoint (base_url in config.yaml).
NAMMA_API_KEY=

# ── Messaging channels (optional — comms tools + Telegram bridge) ──
# Telegram: create a bot via @BotFather, message it once to get your chat id.
# With both set, Namma Agent sends notifications AND you can chat with it from your phone.
NAMMA_TELEGRAM_TOKEN=
NAMMA_TELEGRAM_CHAT_ID=
# Discord OUTBOUND: channel settings → Integrations → Webhooks → New Webhook → URL.
NAMMA_DISCORD_WEBHOOK_URL=
# Discord TWO-WAY (receive + reply): a bot is required — a webhook is send-only.
# Developer Portal → New Application → Bot → copy token; under Privileged Gateway
# Intents enable MESSAGE CONTENT INTENT; invite the bot to your server. Works
# locally (the bot dials out to the Gateway — no public URL). Channel id optional
# (right-click a channel → Copy ID) to restrict listening to one channel.
NAMMA_DISCORD_BOT_TOKEN=
NAMMA_DISCORD_CHANNEL_ID=
# Slack OUTBOUND: Slack app → Incoming Webhooks → Add New Webhook to Workspace → URL.
NAMMA_SLACK_WEBHOOK_URL=
# Slack TWO-WAY, local (recommended): Socket Mode — no public URL needed. In your
# Slack app: enable Socket Mode (generates an app-level xapp- token with
# connections:write), add a bot token (xoxb-, scopes chat:write), and subscribe to
# message events (message.channels / message.im) under Event Subscriptions.
NAMMA_SLACK_APP_TOKEN=
NAMMA_SLACK_BOT_TOKEN=
# Slack TWO-WAY, public-URL alternative (HTTP Events API → /webhooks/slack): the
# app's Signing Secret. Only used when no app-level token is set above.
NAMMA_SLACK_SIGNING_SECRET=
# WhatsApp Cloud API (Meta app → WhatsApp → API Setup). Token, sender phone-number
# id, and recipient in E.164 digits (e.g. 919876543210).
NAMMA_WHATSAPP_TOKEN=
NAMMA_WHATSAPP_PHONE_ID=
NAMMA_WHATSAPP_TO=
# Optional — for two-way WhatsApp: the verify token you set when registering the
# /webhooks/whatsapp callback URL in the Meta dashboard.
NAMMA_WHATSAPP_VERIFY_TOKEN=
# Signal via a signal-cli REST API (run bbernhard/signal-cli-rest-api). Base url,
# the registered sender number, and the recipient number/group id (E.164).
# With these set, Namma both sends AND replies to Signal messages (polling).
NAMMA_SIGNAL_API_URL=
NAMMA_SIGNAL_NUMBER=
NAMMA_SIGNAL_RECIPIENT=

# ── Smart home (optional — Home Assistant tools) ───────────────────
# Long-lived access token; the var name must match smart_home.token_env in config.yaml.
HASS_TOKEN=

# ── Notes ──────────────────────────────────────────────────────────
# • Local providers (Ollama / LM Studio) need NO key — set provider.type
#   accordingly in namma_agent/config.yaml and leave the keys blank.
# • Security tools (port_scan etc.) are OFF until you set security.lab_mode: true
#   and security.authorized_scopes in namma_agent/config.yaml — no env var involved.
